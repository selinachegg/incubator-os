generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id          String       @id @default(cuid())
  title       String
  date        DateTime
  mentor      String       @default("")
  topic       String
  rawNotes    String
  summary     String?
  keyInsights String?      // JSON array stored as string
  actionItems String?      // JSON array stored as string (legacy, still used for AI output)
  tags        String?      // JSON array stored as string
  article     String?      // AI-generated knowledge article HTML
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  actions     ActionItem[]
}

model Setting {
  key   String @id
  value String
}

model ActionItem {
  id          String   @id @default(cuid())
  text        String
  completed   Boolean  @default(false)
  priority    String   @default("medium") // low, medium, high, critical
  dueDate     DateTime?
  notes       String?
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
